# Database — iniettata automaticamente da Railway in production
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/timesheet_hub

# Sicurezza — generare con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
TOKEN_ENCRYPT_KEY=

# Ambiente applicativo. E2E_TEST_MODE=true è lecito solo se ENVIRONMENT è in {ci,local,test}.
# Qualsiasi altro valore (default: production) fa fallire l'avvio (fail-closed, ADR-003-B).
ENVIRONMENT=local

# Test E2E — abilita le rotte test-only (implementate in STORY-008/E3). Usare true/false
# espliciti; richiede ENVIRONMENT in {ci,local,test} quando è true.
E2E_TEST_MODE=false
