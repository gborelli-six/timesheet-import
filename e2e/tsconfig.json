{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./.tsc-out",
    "baseUrl": ".",
    "paths": {
      "@support/*": ["./support/*"],
      "@fixtures/*": ["./fixtures/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": [".tsc-out", "node_modules", "fixtures/xlsx"]
}
