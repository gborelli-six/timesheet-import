# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=timesheet_hub

# Backend — generare con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
TOKEN_ENCRYPT_KEY=

# Ambiente applicativo. Valori leciti per E2E_TEST_MODE=true: ci|local|test.
# Qualsiasi altro valore (default: production) rende E2E_TEST_MODE=true un errore di avvio (ADR-003-B).
ENVIRONMENT=local

# Test E2E — abilita rotte test-only (STORY-008/E3). Usare true/false espliciti:
# un valore vuoto/ambiguo fa fallire l'avvio (ValidationError, fail-closed corretto).
E2E_TEST_MODE=false

# Frontend — Google OAuth Client ID (GCP Console)
VITE_GOOGLE_CLIENT_ID=
